# Impide listado de directorio; los assets estáticos (css/js/img) se sirven con normalidad.

Options -Indexes

# Bloquea ejecución directa de PHP (Apache 2.2)
<IfModule mod_authz_host.c>
    <FilesMatch "\.php$">
        Order deny,allow
        Deny from all
    </FilesMatch>
</IfModule>

# Bloquea ejecución directa de PHP (Apache 2.4)
<IfModule mod_authz_core.c>
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
</IfModule>
